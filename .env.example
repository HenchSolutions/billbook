# =============================================================================
# Required — validated at startup (see src/lib/env.ts)
# =============================================================================

# Backend API base URL (no trailing slash). Used for auth, data, and <link rel="preconnect">
# in the root layout (first-party API origin).
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api

# =============================================================================
# Optional — public / SEO / marketing (NEXT_PUBLIC_* is exposed to the browser)
# Empty or omitted → code fallbacks (see src/lib/site-config.ts, src/lib/env.ts)
# =============================================================================

# Canonical production URL: https://your-domain.com (no trailing slash).
# Drives metadataBase, Open Graph / Twitter absolute URLs, sitemap.xml, robots host,
# JSON-LD @id, and PWA start_url context. Omit in local dev to use the Vercel preview default.
NEXT_PUBLIC_SITE_URL=

# Public contact: /contact mailto + Organization contactPoint in homepage JSON-LD.
# Omit to use it@henchsolutions.com.
NEXT_PUBLIC_CONTACT_EMAIL=

# Google Search Console — HTML tag verification content only (not the full tag).
# Omit if unused.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
